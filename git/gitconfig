[user]
	name = Andrew Volozhanin
	email = scarfacedeb@gmail.com

[init]
	templatedir = ~/.git-templates
	defaultBranch = master

[core]
	editor = nvim
	autocrlf = false
	excludesfile = ~/.gitignore_global
; attributesfile = ~/.gitattributes

[status]
	showUntrackedFiles = all

[push]
	; default = current
  autoSetupRemote = true

[fetch]
	prune = true
  ; prunetags = true

[pull]
	rebase = true

[rebase]
	autostash = true
	autosquash = true

[merge]
	log = true
	tool = nvimdiff
	prompt = false
	conflictstyle = zdiff3

[mergetool]
	keepBackup = false
	path = nvim

[mergetool "nvimdiff"]
	cmd = "nvim -d $BASE $LOCAL $REMOTE $MERGED"

[diff]
	renames = copies
	algorithm = histogram
	renameLimit = 100000000
  colorMoved = default
  colorMovedWS = allow-indentation-change
  context = 10

  ; external = difft
  # Set difftastic as the default difftool, so we don't need to specify
  # `-t difftastic` every time.
  ; tool = difftastic

[pager]
  ; diff = diff-so-fancy | less --tabs=1,5 -RFX
  ; show = diff-so-fancy | less --tabs=1,5 -RFX
  ; diff = delta
  ; show = delta
  ; log = delta
  ; reflog = delta
  # Use a pager if the difftool output is larger than one screenful,
  # consistent with the behaviour of `git diff`.
  difftool = true

; [interactive]
	; diffFilter = delta --color-only

[difftool]
  # Run the difftool immediately, don't ask 'are you sure' each time.
  prompt = false

[delta]
  features = decorations

[filter "media"]
	clean = git media clean %f
	smudge = git media smudge %f
	required = true

[alias]
  log-pickaxe-s  = "!f() { GREPDIFF_REGEX=\"$1\" git -c diff.external=~/.dotfiles/git/pickaxe-diff log  -p --ext-diff -S \"$@\"; }; f"
  # Difftastic aliases, so `git dlog` is `git log` with difftastic and so on.
  dlog = -c diff.external=difft log --ext-diff
  dshow = -c diff.external=difft show --ext-diff
  ddiff = -c diff.external=difft diff

[rerere]
	enabled = true
[column]
	ui = auto
[branch]
	sort = -committerdate
[maintenance]
	repo = /Users/a.volozhanin/projects/cw-seller-center
	repo = /Users/a.volozhanin/projects/cw-lots
	repo = /Users/a.volozhanin/projects/cw-auctioneer-tools

[url "git@github.com:"]
	insteadOf = "gh:"
[log]
	date = iso
[credential]
	helper = 
	helper = /usr/local/share/gcm-core/git-credential-manager
[credential "https://dev.azure.com"]
	useHttpPath = true
